DATABASE_URL=postgresql://reviews_user:reviews_pass@localhost:5432/product_reviews
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=your-secret-key-change-in-production
PORT=3000
NODE_ENV=development

# Notifications
NOTIFICATIONS_ENABLED=true
ADMIN_EMAIL=admin@example.com

# AI Insights (optional: enables LLM-powered summaries)
# OPENAI_API_KEY=sk-...

# File Storage
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=/api/uploads
MAX_FILE_SIZE=5242880
